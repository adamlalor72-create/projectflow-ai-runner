{
  "name": "@dealflow/cartographer",
  "version": "0.1.0",
  "description": "CBC Cartographer — maps, verifies, and loads SAP CBC customizing activities",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "validate:schemas": "node --import tsx test/validate-schemas.ts",
    "cost:summary": "node --import tsx services/telemetry/daily-summary.ts"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "tsx": "^4.19.0",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0"
  }
}
