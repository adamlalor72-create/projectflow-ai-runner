{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dealflow.ai/cartographer/knowledge-frontmatter.schema.json",
  "title": "CBC Cartographer Knowledge File Frontmatter",
  "description": "Validates YAML frontmatter in Cartographer knowledge markdown files.",
  "type": "object",
  "required": ["last_updated", "confidence", "verified_by"],
  "additionalProperties": false,
  "properties": {
    "activity_id": {
      "type": ["string", "integer", "null"],
      "description": "SAP activity ID. Null for general (non-activity-specific) knowledge."
    },
    "activity_name": {
      "type": "string",
      "description": "Human-readable activity name"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Confidence level in the knowledge content"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "description": "URLs of sources used to produce this knowledge"
    },
    "verified_by": {
      "type": "string",
      "description": "Agent name + version, 'human-pending', or 'human-verified'",
      "examples": ["researcher-agent@0.1.0", "human-pending", "human-verified"]
    },
    "related_activities": {
      "type": "array",
      "items": { "type": ["string", "integer"] },
      "description": "Activity IDs of related customizing activities"
    },
    "scope_item_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Related SAP scope items"
    },
    "purpose": {
      "type": "string",
      "description": "Purpose description for this knowledge file"
    },
    "uncertainty_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["note"],
        "properties": {
          "note": {
            "type": "string",
            "description": "Description of what is uncertain"
          },
          "line": {
            "type": "integer",
            "description": "Approximate line number in the markdown body"
          }
        }
      },
      "description": "Researcher output: areas where sources conflict or coverage is thin"
    }
  }
}
